  m_text: "\u0421\u043B\u0435\u0432\u0430 \u043E\u0442 \u0412\u0430\u0441 \u043D\u0430
    \u043F\u043E\u0434\u043E\u043A\u043E\u043D\u043D\u0438\u043A\u0435 \u043B\u0435\u0436\u0430\u0442
    \u0432\u0441\u0435 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0435 \u0434\u043B\u044F
    \u0434\u0430\u043D\u043D\u043E\u0439 \u0441\u0438\u043C\u0443\u043B\u044F\u0446\u0438\u0438
    \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B:\n\n1. \u0413\u0430\u0437\u043E\u0430\u043D\u0430\u043B\u0438\u0437\u0430\u0442\u043E\u0440
    - \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0435\u0442, \u0435\u0441\u0442\u044C
    \u043B\u0438 \u0443\u0442\u0435\u0447\u043A\u0430 \u0433\u0430\u0437\u0430 \u0432
    \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u043C \u0440\u0430\u0434\u0438\u0443\u0441\u0435
    \u0432\u043E\u043A\u0440\u0443\u0433 \u043D\u0435\u0433\u043E;\n\n2. \u0421\u043F\u0438\u0447\u043A\u0430
    - \u043C\u043E\u0436\u0435\u0442 \u0437\u0430\u0436\u0435\u0447\u044C \u043E\u0433\u043E\u043D\u044C
    \u0435\u0441\u043B\u0438 \u043D\u0430\u0432\u0435\u0441\u0442\u0438 \u0435\u0451
    \u0432 \u043E\u0431\u043B\u0430\u0441\u0442\u044C \u043D\u0430\u0434 \u0432\u043A\u043B\u044E\u0447\u0451\u043D\u043D\u043E\u0439
    \u0433\u0430\u0437\u043E\u0432\u043E\u0439 \u043A\u043E\u043D\u0444\u043E\u0440\u043A\u043E\u0439."
