    \u0432\u043A\u043B\u044E\u0447\u0438\u0432 \u0442\u0435\u043C \u0441\u0430\u043C\u044B\u043C
    \u0433\u0430\u0437;\n\n2. \u041F\u043E\u0434\u043D\u0435\u0441\u0442\u0438 \u0433\u0430\u0437\u043E\u0430\u043D\u0430\u043B\u0438\u0437\u0430\u0442\u043E\u0440
    \u043A \u0433\u0430\u0437\u0443 - \u0432\u044B\u0441\u0432\u0435\u0442\u0438\u0442\u0441\u044F
    \u0441\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u0435 \u043E\u0431 \u0443\u0442\u0435\u0447\u043A\u0435
    \u0433\u0430\u0437\u0430;\n\n3. \u0412\u0437\u044F\u0442\u044C \u0432 \u0440\u0443\u043A\u0438
    \u0441\u043F\u0438\u0447\u043A\u0443 (\u043B\u0435\u0436\u0438\u0442 \u0443 \u043E\u043A\u043D\u0430)
    \u0438 \u043F\u043E\u0434\u043D\u0435\u0441\u0442\u0438 \u0435\u0451 \u043A \u0433\u0430\u0437\u0443
    - \u0437\u0430\u0433\u043E\u0440\u0438\u0442\u0441\u044F \u043F\u043B\u0430\u043C\u044F;\n\n4.
    \u041F\u043E\u0434\u043D\u0435\u0441\u0442\u0438 \u0433\u0430\u0437\u043E\u0430\u043D\u043B\u0438\u0437\u0430\u0442\u043E\u0440
    \u043A \u043A\u043E\u043D\u0444\u043E\u0440\u043A\u0435 - \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442 \u0440\u0430\u0431\u043E\u0442\u044B
    \u0433\u0430\u0437\u043E\u0430\u043D\u0430\u043B\u0438\u0437\u0430\u0442\u043E\u0440\u0430."
